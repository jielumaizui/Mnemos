# Memos-Wiki Knowledge System Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# REQUIRED: Memos API Configuration
# ============================================

# Memos API Token (Required)
# Get from your Memos instance: Settings > API > Generate Token
MEMOS_TOKEN=your_memos_api_token_here

# Memos API URL (Optional, defaults to https://memos.me/api/v1)
MEMOS_API_URL=https://memos.me/api/v1

# ============================================
# OPTIONAL: Memos Organization
# ============================================

# Project tag for organizing memos (optional)
MEMOS_PROJECT=wiki-project

# Session identifier for tracking (auto-generated if not set)
# MEMOS_SESSION=session-2024-001

# Agent identifier for API calls
MEMOS_AGENT=mnemos-client

# ============================================
# OPTIONAL: AI/LLM Integration
# ============================================

# Anthropic API Key (for Claude integration)
# ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI API Key (for GPT integration)
# OPENAI_API_KEY=your_openai_api_key

# ============================================
# OPTIONAL: System Paths
# ============================================

# Base directory for wiki storage (defaults to ~/wiki)
# WIKI_BASE_PATH=/Users/yourname/wiki

# Database directory (defaults to ~/.claude)
# DB_PATH=/Users/yourname/.claude

# L1 Buffer directory for raw content (defaults to ~/memos-client/hermes_l1_buffer)
# L1_BUFFER_PATH=/Users/yourname/memos-client/hermes_l1_buffer

# ============================================
# OPTIONAL: Feature Flags
# ============================================

# Enable auto-clean (true/false)
# AUTO_CLEAN_ENABLED=true

# Enable heat tracking (true/false)
# HEAT_TRACKING_ENABLED=true

# Enable quality assessment (true/false)
# QUALITY_ASSESSMENT_ENABLED=true

# Debug mode (true/false)
# DEBUG=false

# ============================================
# OPTIONAL: Performance Tuning
# ============================================

# Maximum batch size for ingest
# INGEST_BATCH_SIZE=10

# Index flush interval in seconds
# INDEX_FLUSH_INTERVAL=300

# Daily heat cap
# DAILY_HEAT_CAP=50
